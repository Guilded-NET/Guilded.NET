aram name=\"image\">Image of the icon</param>\n        /// <param name=\"url\">URL of the author</param>\n        /// <returns>Author</returns>\n        public static EmbedAuthor Generate(string name, Uri image, Uri url) =>\n            new EmbedAuthor\n            {\n                Name = name,\n                IconUrl = image,\n                Url = url\n            };\n    }\n}"
