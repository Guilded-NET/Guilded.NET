          "text": "using Newtonsoft.Json;\nusing System;\nusing System.ComponentModel;\n\nnamespace Guilded.NET.Objects\n{\n    /// <summary>\n    /// Emote in status or in a message.\n    /// </summary>\n    public class ChatEmote : ClientObject\n    {\n        /// <summary>\n        /// ID of the emote.\n        /// </summary>\n        /// <value>Emote ID</value>\n        [JsonProperty(\"id\", Required = Required.Always)]\n        public uint Id\n        {\n            get; set;\n        }\n        /// <summary>\n        /// URL to emote's PNG file.\n        /// </summary>\n        /// <value>.PNG URL</value>\n        [JsonProperty(\"png\")]\n        [DefaultValue(null)]\n        public Uri PNGUrl\n        {\n            get; set;\n        }\n        /// <summary>\n        /// URL to emote's APNG(Animated PNG) file.\n        /// </summary>\n        /// <value>.APNG URL</value>\n        [JsonProperty(\"apng\")]\n        [DefaultValue(null)]\n        public Uri APNGUrl\n        {\n            get; set;\n        }\n        /// <summary>\n        /// URL to emote's WebP file.\n        /// </summary>\n        /// <value>.WEBP URL</value>\n        [JsonProperty(\"webp\")]\n        [DefaultValue(null)]\n        public Uri WebPUrl\n        {\n            get; set;\n        }\n        /// <summary>\n        /// Name of the emote.\n        /// </summary>\n        /// <value>Name</value>\n        [JsonProperty(\"name\", Required = Required.Always)]\n        public string Name\n        {\n            get; set;\n        }\n        /// <summary>\n        /// Checks if object is equal to this chat emote.\n        /// </summary>\n        /// <param name=\"obj\">Object to compare</param>\n        /// <returns>Equal</returns>\n        public override bool Equals(object obj) =>\n            obj is ChatEmote emote && emote.Id == Id;\n        /// <summary>\n        /// Gets a hashcode of this emote.\n        /// </summary>\n        /// <returns>Emote</returns>\n        public override int GetHashCode() =>\n            HashCode.Combine(Id, Name);\n    }\n}"
        }
      ]
    }
  ],
