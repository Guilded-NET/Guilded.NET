<?xml version="1.0" encoding="utf-8"?>
<package>
    <metadata>
        <id>Guilded.NET</id>
        <version>0.0.9</version>
        <title>Guilded.NET</title>
        <authors>IdkGoodName</authors>
        <owners>IdkGoodName</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <license type="expression">MIT</license>
        <projectUrl>https://github.com/IdkGoodName/Guilded.NET</projectUrl>
        <icon>icon.png</icon>
        <description>API wrapper for Guilded</description>
        <releaseNotes>
- Content updated event
- Voice/stream channel joined and left events
- Ability to create another websocket for a team(this means channel created and channel deleted events)
- Documentation fixes
- Set referer header
- Channel created, deleted and updated events
        </releaseNotes>
        <copyright>Copyright 2020</copyright>
        <tags>wrapper,api,chat,guilded</tags>
        <dependencies>
            <dependency id="RestSharp" version="106.11.7" />
            <dependency id="Websocket.Client" version="4.3.21" />
            <dependency id="Newtonsoft.Json" version="12.0.3" />
            <dependency id="Newtonsoft.Json.Schema" version="3.0.13" />
            <dependency id="Websocket.Client" version="4.3.21" />
            <dependency id="System.Reactive" version="4.4.1" />
            <dependency id="Guilded.NET.API" version="0.0.9" />
            <dependency id="Guilded.NET.Objects" version="0.0.9" />
        </dependencies>
    </metadata>
    <files>
        <file src="readme.md" target="" />
        <file src="icon.png" target="" />
    </files>
</package>